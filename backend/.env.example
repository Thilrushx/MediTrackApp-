# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=meditrack
DB_USER=root
DB_PASSWORD=yourpassword
DB_LOGGING=false

# Connection pool (optional — defaults shown)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQ=30000
DB_POOL_IDLE=10000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES=8h

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# e.g. http://localhost:3000,https://myapp.azurewebsites.net
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# ── Doctor self-registration code ─────────────────────────────────────────────
DOCTOR_REGISTER_CODE=MEDITRACK_DOCTOR_2026
